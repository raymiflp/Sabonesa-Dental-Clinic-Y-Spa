{
  "name": "sistema-betty-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npx prisma db push && node prisma/seed.js && node src/index.js",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:e2e": "node prisma/seed-e2e.js",
    "db:clean-demo": "node prisma/clean-demo.js",
    "db:studio": "npx prisma studio",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@vitest/coverage-v8": "^3.1.0",
    "prisma": "^6.0.0",
    "supertest": "^7.1.0",
    "testcontainers": "^12.0.1",
    "vitest": "^3.1.0"
  }
}
